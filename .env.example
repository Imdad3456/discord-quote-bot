DISCORD_TOKEN=your-bot-token-here
QUOTES_CHANNEL_ID=123456789012345678
QUOTES_FILE=quotes.json
NAMES_FILE=names.json
NICKNAMES_FILE=nicknames.json
# Optional: Discord user ID to DM when a quote's attribution can't be resolved.
# If unset, the bot replies in the quotes channel instead.
MOD_USER_ID=
# Optional: UTC hour (0-23) to post the daily "Quote of the Day". Defaults to 13 (1pm UTC).
QUOTE_OF_DAY_HOUR_UTC=13
